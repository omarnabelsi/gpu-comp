{
  "buildCommand": "npm run build && npx prisma generate",
  "devCommand": "npm run dev",
  "installCommand": "npm install && npx prisma generate",
  "env": {
    "DATABASE_URL": "",
    "DIRECT_URL": "",
    "SUPABASE_URL": "",
    "SUPABASE_SERVICE_ROLE_KEY": "",
    "NEXTAUTH_SECRET": "",
    "NEXTAUTH_URL": ""
  },
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
